						<string name="ScriptGuid">{88829C5D-7F90-41C7-85AA-4E2EA7566A97}</string>
						<ProtectedString name="Source"><![CDATA[--!strict

local Disposer = {}
Disposer.__index = Disposer

function Disposer.New()
	local disposer = setmetatable({}, Disposer)
	
	disposer.destructors = {}
	
	return disposer
end

function Disposer:Bind(destructor: any): ()
	table.insert(self.destructors, destructor)
end

function Disposer:Dispose()
	for _,destructor in self.destructors do
		if typeof(destructor) == 'RBXScriptConnection' then
			destructor:Disconnect()
		else
			destructor()
		end
	end
	self.destructors = {}
end

return Disposer]]></ProtectedString>

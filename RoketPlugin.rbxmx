						<ProtectedString name="Source"><![CDATA[--!strict
--Network Event

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Util = require(script.Parent.Util)

local NetEvent = {}
NetEvent.__index = NetEvent

type LoadOptions = {
	id: string?;
	unreliable: boolean?
}
function NetEvent.Load(opts: LoadOptions)
	local netEvent = setmetatable({}, NetEvent)
	
	local id = opts.id
	if not id then
		id = Util.GetIDFromTraceback(2)
	end
	netEvent.id = id

	local remoteEvents = ReplicatedStorage.__Roket.Events
	if RunService:IsServer() then
		local remoteEvent = remoteEvents:FindFirstChild(id)
		if not remoteEvent then
			remoteEvent = Instance.new(opts.unreliable and "UnreliableRemoteEvent" or "RemoteEvent")
			remoteEvent.Name = id
			remoteEvent.Parent = remoteEvents
		end
		netEvent.remoteEvent = remoteEvent
	else
		netEvent.remoteEvent = remoteEvents:WaitForChild(id)
	end

	return netEvent
end

function NetEvent:Fire(...: any): ()
	if RunService:IsServer() then
		local arg1 = ({...})[1]
		if typeof(arg1) == "Instance" and arg1:IsA('Player') then
			self.remoteEvent:FireClient(...)
		else
			self.remoteEvent:FireAllClients(...)
		end
	else
		self.remoteEvent:FireServer(...)
	end
end

function NetEvent:Listen(listener: (...any) -> ()): ()
	if RunService:IsServer() then
		return self.remoteEvent.OnServerEvent:Connect(listener)
	else
		return self.remoteEvent.OnClientEvent:Connect(listener)
	end
end

return NetEvent.Load]]></ProtectedString>

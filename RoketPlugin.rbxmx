					<string name="ScriptGuid">{359AC1C2-AD1D-45F0-B31E-7D5651F573E4}</string>
					<ProtectedString name="Source"><![CDATA[--!strict

local Roket = {}

Roket.Disposer = require(script.Disposer)
Roket.NetEvent = require(script.NetEvent)

function Roket.Start(moduleScriptsParent: Instance)
	for _,child in moduleScriptsParent:GetChildren() do
		if child:IsA("ModuleScript") then
			local module = require(child)
			if module.RoketStart and not child:GetAttribute("__RoketModuleStarted") then
				child:SetAttribute("__RoketModuleStarted", true)
				module.RoketStart()
			end
		end
	end
end

return Roket]]></ProtectedString>

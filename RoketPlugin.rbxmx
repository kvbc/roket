						<string name="ScriptGuid">{D13588CF-9A86-4939-972D-9336C9EF4923}</string>
						<ProtectedString name="Source"><![CDATA[--!strict

-- TODO
-- also maybe make it kinda work with a peristent database storage?

local NetEvent = require(script.Parent.NetEvent)
local Util = require(script.Parent.Util)

type Type = {
	Set: (self: Type, newValue: any) -> ();
	Get: (self: Type) -> any;
	Watch: (self: Type, listener: (newValue:any)->()) -> ();
}
local NetProperty = {}
NetProperty.__index = NetProperty

type LoadOptions = {
	defaultValue: any?;
	unreliable: boolean?;
	id: string?
}
function NetProperty.Load(opts: LoadOptions): Type
	local self = setmetatable({}, NetProperty)

	local id = opts.id
	if not id then
		id = Util.GetIDFromTraceback(2)
	end
	self.id = id
	
	self.value = opts.defaultValue
	self.netEvent = NetEvent {
		id = "__RoketNetPropertyChanged",
		unreliable = opts.unreliable
	}
	self:Watch(function(newValue: any)
		self.value = newValue
	end)

	return (self :: any) :: Type
end

function NetProperty:Set(newValue: any): ()
	self.value = newValue
	self.netEvent:Fire(self.id, newValue)
end

function NetProperty:Get(): any
	return self.value
end

function NetProperty:Watch(listener: (newValue: any) -> ())
	listener(self.value)
	return self.netEvent:Listen(function(propId: string, newValue: any)
		if propId ~= self.id then return end
		listener(newValue)
	end)
end

return NetProperty.Load]]></ProtectedString>
